CAN_WEN_APP_NAME="Can Wen API"
CAN_WEN_DEBUG=false
CAN_WEN_CORS_ORIGINS='["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174"]'
CAN_WEN_DATABASE_URL=postgresql+psycopg://canwen:canwen123@127.0.0.1:5432/can_wen
CAN_WEN_AUTH_SECRET_KEY=change-me-in-production
CAN_WEN_AUTH_DEV_CODE_ENABLED=true
CAN_WEN_API_RATE_LIMIT_REQUESTS_PER_MINUTE=300
CAN_WEN_AUTH_RATE_LIMIT_REQUESTS_PER_MINUTE=60
CAN_WEN_SECURITY_HEADERS_ENABLED=true
CAN_WEN_ALLOWED_EMAIL_DOMAINS='["qq.com","vip.qq.com","foxmail.com","163.com","126.com","yeah.net","188.com","vip.163.com","vip.126.com"]'

# Optional SMTP config. Without these values, email login runs in local dev mode
# and returns dev_code from the verification-code API response.
CAN_WEN_SMTP_HOST=
CAN_WEN_SMTP_PORT=465
CAN_WEN_SMTP_USERNAME=
CAN_WEN_SMTP_PASSWORD=
CAN_WEN_SMTP_FROM_EMAIL=
CAN_WEN_SMTP_USE_SSL=true

# S3-compatible object storage for user avatars.
# The bucket should expose objects through CAN_WEN_STORAGE_PUBLIC_BASE_URL.
CAN_WEN_STORAGE_ENDPOINT_URL=
CAN_WEN_STORAGE_ACCESS_KEY_ID=
CAN_WEN_STORAGE_SECRET_ACCESS_KEY=
CAN_WEN_STORAGE_BUCKET=
CAN_WEN_STORAGE_REGION=
CAN_WEN_STORAGE_PUBLIC_BASE_URL=
CAN_WEN_AVATAR_UPLOAD_MAX_BYTES=2097152
CAN_WEN_MULTIMODAL_ATTACHMENT_MAX_BYTES=83886080
CAN_WEN_MULTIMODAL_ATTACHMENT_MAX_COUNT=6

# OpenAI-compatible chat model for diagnosis.
# The backend also accepts OPENAI_API_KEY, OPENAI_BASE_URL, and MODEL_ID.
CAN_WEN_OPENAI_API_KEY=
CAN_WEN_OPENAI_BASE_URL=https://api.openai.com/v1
CAN_WEN_OPENAI_MODEL_ID=gpt-5-nano
CAN_WEN_OPENAI_TIMEOUT_SECONDS=60
CAN_WEN_PUBLIC_FRONTEND_BASE_URL=http://127.0.0.1:5174

# Evidence-first diagnosis agents. The chat model performs query planning,
# evidence assessment and grounded answer generation. Dense retrieval and
# reranking use the same published model IDs as the management build pipeline.
CAN_WEN_DIAGNOSIS_AGENT_ENABLED=true
CAN_WEN_DIAGNOSIS_AGENT_MAX_RETRIEVAL_ROUNDS=2
CAN_WEN_DIAGNOSIS_AGENT_DENSE_TOP_K=30
CAN_WEN_DIAGNOSIS_AGENT_BM25_TOP_K=30
CAN_WEN_DIAGNOSIS_AGENT_FUSION_TOP_K=20
CAN_WEN_DIAGNOSIS_AGENT_FINAL_EVIDENCE_LIMIT=8
# Shared service credential for query-side embedding/rerank. Do not substitute
# an end user's chat-model key here. DASHSCOPE_API_KEY is also accepted.
CAN_WEN_KNOWLEDGE_MODEL_API_KEY=
CAN_WEN_KNOWLEDGE_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
CAN_WEN_KNOWLEDGE_EMBEDDING_MODEL_ID=text-embedding-v4
CAN_WEN_KNOWLEDGE_EMBEDDING_DIMENSIONS=1024
CAN_WEN_KNOWLEDGE_RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
CAN_WEN_KNOWLEDGE_RERANK_MODEL_ID=qwen3-rerank

# Query-side access to the stores populated by backend_mger. The user API is
# read-only and filters every query to the current published snapshot.
CAN_WEN_QDRANT_URL=http://127.0.0.1:6333
CAN_WEN_QDRANT_API_KEY=
CAN_WEN_QDRANT_COLLECTION=silkworm_qa_v1
CAN_WEN_OPENSEARCH_URL=http://127.0.0.1:9200
CAN_WEN_OPENSEARCH_USERNAME=
CAN_WEN_OPENSEARCH_PASSWORD=
CAN_WEN_OPENSEARCH_INDEX=silkworm_qa_v1
# Must be the same Neo4j Aura database used by backend_mger (neo4j+s://...).
CAN_WEN_NEO4J_URI=
CAN_WEN_NEO4J_USER=
CAN_WEN_NEO4J_PASSWORD=
CAN_WEN_NEO4J_DATABASE=
