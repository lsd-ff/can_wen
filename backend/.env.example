CAN_WEN_APP_NAME="Can Wen API"
CAN_WEN_DEBUG=false
CAN_WEN_CORS_ORIGINS='["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174"]'
CAN_WEN_DATABASE_URL=postgresql+psycopg://canwen:canwen123@127.0.0.1:5432/can_wen
CAN_WEN_AUTH_SECRET_KEY=change-me-in-production
CAN_WEN_AUTH_DEV_CODE_ENABLED=true
CAN_WEN_ALLOWED_EMAIL_DOMAINS='["qq.com","vip.qq.com","foxmail.com","163.com","126.com","yeah.net","188.com","vip.163.com","vip.126.com"]'

# Optional SMTP config. Without these values, email login runs in local dev mode
# and returns dev_code from the verification-code API response.
CAN_WEN_SMTP_HOST=
CAN_WEN_SMTP_PORT=465
CAN_WEN_SMTP_USERNAME=
CAN_WEN_SMTP_PASSWORD=
CAN_WEN_SMTP_FROM_EMAIL=
CAN_WEN_SMTP_USE_SSL=true
