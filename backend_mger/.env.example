CANW_ADMIN_DATABASE_URL=postgresql+psycopg://canwen:canwen123@127.0.0.1:5432/can_wen
CANW_ADMIN_AUTH_SECRET_KEY=replace-with-a-long-random-secret
CANW_ADMIN_ENCRYPTION_KEY=replace-with-a-different-long-random-secret
CANW_ADMIN_CORS_ORIGINS=["http://127.0.0.1:5175"]
CANW_ADMIN_BOOTSTRAP_EMAIL=admin@example.com
CANW_ADMIN_BOOTSTRAP_PASSWORD=Change-this-before-production
CANW_ADMIN_AUTO_CREATE_SCHEMA=true

# 异步任务
CANW_ADMIN_REDIS_URL=redis://127.0.0.1:6379/0
CANW_ADMIN_CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CANW_ADMIN_CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CANW_ADMIN_KNOWLEDGE_CHUNK_TARGET_TOKENS=1200
CANW_ADMIN_KNOWLEDGE_AUTO_PUBLISH_SCORE=0.9
CANW_ADMIN_KNOWLEDGE_MAX_REFLECTION_ROUNDS=2

# 文档存储；默认使用本机目录，已有 S3 兼容存储时切换为 s3。
CANW_ADMIN_KNOWLEDGE_STORAGE_BACKEND=local
CANW_ADMIN_KNOWLEDGE_STORAGE_ROOT=var/knowledge
CANW_ADMIN_STORAGE_ENDPOINT_URL=
CANW_ADMIN_STORAGE_ACCESS_KEY_ID=
CANW_ADMIN_STORAGE_SECRET_ACCESS_KEY=
CANW_ADMIN_STORAGE_BUCKET=
CANW_ADMIN_STORAGE_REGION=

# 外部解析与模型密钥只写本地 .env，不要提交到 Git。
MINERU_TOKEN=
DASHSCOPE_API_KEY=
CANW_ADMIN_MINERU_BASE_URL=https://mineru.net/api/v4
CANW_ADMIN_DASHSCOPE_CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CANW_ADMIN_DASHSCOPE_RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
CANW_ADMIN_QA_MODEL_ID=qwen3.7-plus-2026-05-26
CANW_ADMIN_KG_MODEL_ID=qwen3.7-plus-2026-05-26
CANW_ADMIN_EXPERT_MODEL_ID=qwen3.7-max-2026-06-08
CANW_ADMIN_EMBEDDING_MODEL_ID=text-embedding-v4
CANW_ADMIN_EMBEDDING_DIMENSIONS=1024
CANW_ADMIN_RERANK_MODEL_ID=qwen3-rerank

# 知识存储服务
CANW_ADMIN_QDRANT_URL=http://127.0.0.1:6333
CANW_ADMIN_QDRANT_COLLECTION=silkworm_qa_v1
CANW_ADMIN_OPENSEARCH_URL=http://127.0.0.1:9200
CANW_ADMIN_OPENSEARCH_INDEX=silkworm_qa_v1
# Neo4j Aura 是项目唯一业务图数据库；请将真实凭据仅写入被 Git 忽略的 .env。
CANW_ADMIN_NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
CANW_ADMIN_NEO4J_USER=<instance-id>
CANW_ADMIN_NEO4J_PASSWORD=
CANW_ADMIN_NEO4J_DATABASE=<database-name>
